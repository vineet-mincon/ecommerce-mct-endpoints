# eBay OAuth credentials
# Found in your eBay Developer account under "Application Keys"
EBAY_APP_ID=
EBAY_CERT_ID=

# eBay user-level refresh token (obtained via OAuth Authorization Code flow)
EBAY_REFRESH_TOKEN=

# Space-separated list of eBay OAuth scopes (optional — defaults to api_scope)
EBAY_SCOPES=https://api.ebay.com/oauth/api_scope

# Server config
PORT=3000
BASE_URL=http://localhost:3000
